# Runtime
PORT=8790
NODE_ENV=development
PUBLIC_BASE_URL=http://127.0.0.1:8790
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_MAX_ENTRIES=10000

# Temporary HTML reports. Production requires an absolute storage path and a
# 32-byte base64 or 64-character hex encryption key.
REPORT_TTL_HOURS=24
REPORT_MAX_ENTRIES=2000
REPORT_STORAGE_DIR=
REPORT_ENCRYPTION_KEY=

# Production x402 seller configuration
X402_ENABLED=false
X402_REQUIRE_PAYMENT=false
X402_PAY_TO=0xYourXLayerReceivingAddress
X402_NETWORK=eip155:196
X402_TIMEOUT_SECONDS=300
X402_INIT_TIMEOUT_MS=10000
OKX_SYNC_SETTLE=true
OKX_BASE_URL=https://web3.okx.com

# Keep these values only in your local .env or deployment secret manager.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
